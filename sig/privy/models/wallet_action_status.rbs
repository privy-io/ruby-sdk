module Privy
  module Models
    type wallet_action_status = :pending | :succeeded | :rejected | :failed

    module WalletActionStatus
      extend Privy::Internal::Type::Enum

      PENDING: :pending
      SUCCEEDED: :succeeded
      REJECTED: :rejected
      FAILED: :failed

      def self?.values: -> ::Array[Privy::Models::wallet_action_status]
    end
  end
end
