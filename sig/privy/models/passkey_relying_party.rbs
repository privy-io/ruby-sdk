module Privy
  module Models
    type passkey_relying_party = { name: String, id: String }

    class PasskeyRelyingParty < Privy::Internal::Type::BaseModel
      attr_accessor name: String

      attr_reader id: String?

      def id=: (String) -> String

      def initialize: (name: String, ?id: String) -> void

      def to_hash: -> { name: String, id: String }
    end
  end
end
