module Privy
  module Models
    type custom_jwt_link_request_body = { token: String }

    class CustomJwtLinkRequestBody < Privy::Internal::Type::BaseModel
      attr_reader token: String?

      def token=: (String) -> String

      def initialize: (?token: String) -> void

      def to_hash: -> { token: String }
    end
  end
end
