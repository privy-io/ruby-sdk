module Privy
  module Models
    type passkey_init_input = { token: String, relying_party: String }

    class PasskeyInitInput < Privy::Internal::Type::BaseModel
      attr_reader token: String?

      def token=: (String) -> String

      attr_reader relying_party: String?

      def relying_party=: (String) -> String

      def initialize: (?token: String, ?relying_party: String) -> void

      def to_hash: -> { token: String, relying_party: String }
    end
  end
end
